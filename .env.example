# ─── Local ────────────────────────────────────────────────────
# Porta local para acessar o portfolio em desenvolvimento
APP_PORT=3000

# ─── Produção ─────────────────────────────────────────────────
# Nome do network externo do Nginx Proxy Manager no servidor
# Para descobrir: docker network ls | grep npm
PROXY_NETWORK_NAME=npm_default
